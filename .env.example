DATABASE_URL="mysql://USER:PASSWORD@HOST:3306/fizza"

# Required: minimum 32 random characters. Generate with: openssl rand -base64 32
SESSION_SECRET=

APP_URL=http://localhost:3000

# ── Distance calculation (server-side only, never expose to client) ─────────────
# Default provider. Supported: OPENROUTESERVICE
DISTANCE_PROVIDER=OPENROUTESERVICE

# OpenRouteService — free tier at https://openrouteservice.org
# Used for road-distance geocoding and routing. Never expose to client.
OPENROUTESERVICE_API_KEY=

# Future providers (not yet implemented):
# GOOGLE_MAPS_API_KEY=
# MAPBOX_ACCESS_TOKEN=

# ── Client-side map display only (safe to expose via NEXT_PUBLIC_ prefix) ────────
NEXT_PUBLIC_MAPBOX_TOKEN=

# ── Payment gateway ───────────────────────────────────────────────────────────────
MYFATOORAH_API_KEY=
MYFATOORAH_BASE_URL=
MYFATOORAH_WEBHOOK_SECRET=

# ── File storage ──────────────────────────────────────────────────────────────────
STORAGE_DRIVER=local
UPLOAD_MAX_SIZE_MB=5
