DATABASE_URL="mysql://USER:PASSWORD@HOST:3306/fizza"

# Required: minimum 32 random characters. Generate with: openssl rand -base64 32
SESSION_SECRET=

APP_URL=http://localhost:3000

# ── Distance calculation (server-side only, never expose to client) ─────────────
# AUTO = ORS if key exists, else OSRM free demo, else haversine estimate
DISTANCE_PROVIDER=AUTO
DISTANCE_FALLBACK_ROAD_FACTOR=1.35
OSRM_BASE_URL=https://router.project-osrm.org

# OpenRouteService — recommended for production SLA
OPENROUTESERVICE_API_KEY=

# Future providers (not yet implemented):
# GOOGLE_MAPS_API_KEY=
# MAPBOX_ACCESS_TOKEN=

# ── Map places registry ─────────────────────────────────────────────────────────
# Radius (meters) to snap pin click/drag to nearest verified local place
MAP_LOCAL_PLACE_SNAP_RADIUS_METERS=250

# ── Client-side map display only (safe to expose via NEXT_PUBLIC_ prefix) ────────
# Leaflet tile layer — defaults to OpenStreetMap standard tiles
# NEXT_PUBLIC_MAP_TILE_URL=https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png
# NEXT_PUBLIC_MAP_ATTRIBUTION=© OpenStreetMap contributors
NEXT_PUBLIC_MAPBOX_TOKEN=

# ── Payment gateway ───────────────────────────────────────────────────────────────
MYFATOORAH_API_KEY=
MYFATOORAH_BASE_URL=
# Set to false to disable automated driver payouts via Multi-Vendors
MYFATOORAH_MULTI_VENDOR_ENABLED=true
# Default MyFatoorah bank id for CreateSupplier (from MyFatoorah portal)
MYFATOORAH_DEFAULT_BANK_ID=1

# Required for /api/cron/* routes. Generate with: openssl rand -base64 32
# Vercel Cron sends Authorization: Bearer <CRON_SECRET> automatically.
CRON_SECRET=

# ── File storage ──────────────────────────────────────────────────────────────────
# local = dev (public/uploads). r2 = Cloudflare R2 for production — see docs/storage-production.md
STORAGE_DRIVER=local
UPLOAD_MAX_SIZE_MB=5

# Cloudflare R2 (production)
# STORAGE_DRIVER=r2
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET=fizza-uploads
# R2_PUBLIC_BASE_URL=https://uploads.yourdomain.com
