datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum UserRole {
  PARENT
  RIDER
  DRIVER
  ADMIN
}

enum SubscriptionStatus {
  PENDING
  ACTIVE
  PAUSED
  EXPIRED
  CANCELLED
}

enum TripStatus {
  SCHEDULED
  DRIVER_ASSIGNED
  /// Driver started pre-trip location sharing (within 10 min of pickup)
  PRE_TRIP
  /// Driver en route to pickup location
  ON_THE_WAY
  /// Driver has arrived at the pickup location
  ARRIVED_PICKUP
  /// Rider has been picked up
  PICKED_UP
  /// Driver en route to drop-off location
  EN_ROUTE_DROPOFF
  /// Driver has arrived at the drop-off location
  ARRIVED_DROPOFF
  COMPLETED
  CANCELLED
  /// Rider did not show at pickup
  NO_SHOW
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum SafetyStatus {
  PENDING
  APPROVED
  RESOLVED
  REJECTED
}

enum VehicleType {
  ECONOMY
  COMFORT
  FAMILY
  VAN
  BUS
  PREMIUM
}

enum DriverApplicationStatus {
  PENDING
  APPROVED
  REJECTED
  NEEDS_CHANGES
}

enum TripDirection {
  ONE_WAY
  ROUND_TRIP
}

enum TripLegType {
  OUTBOUND
  RETURN
}

enum TripFinancialReviewStatus {
  PENDING
  PAY_DRIVER
  NO_PAY_DRIVER
  REFUND_PARENT
  CREDIT_PARENT
  KEEP_REVENUE
  INCIDENT
}

enum PaymentPurpose {
  WALLET_TOP_UP
  SUBSCRIPTION_PAYMENT
}

enum WalletTransactionType {
  CREDIT
  DEBIT
  REFUND
  TOP_UP
  SUBSCRIPTION_PAYMENT
}

enum WalletTransactionSource {
  MANUAL_ADJUSTMENT
  TRIP_FINANCIAL_CREDIT
  SUBSCRIPTION_PAYMENT
  TOP_UP
  REFUND_MANUAL_PENDING
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  role         UserRole @default(PARENT)
  createdAt    DateTime @default(now()) @map("created_at")
  profile      Profile?

  @@map("users")
}

model Profile {
  id                    String              @id
  role                  UserRole            @default(PARENT)
  fullName              String              @map("full_name")
  phone                 String?
  avatarUrl             String?             @map("avatar_url") @db.Text
  /// "FAMILY" (default) or "DRIVER_PORTAL" — set at registration to separate
  /// normal family accounts from driver applicant accounts.
  /// Migration required: ALTER TABLE profiles ADD COLUMN registration_source VARCHAR(32) NOT NULL DEFAULT 'FAMILY'
  registrationSource    String              @default("FAMILY") @map("registration_source")
  createdAt             DateTime            @default(now()) @map("created_at")
  updatedAt             DateTime            @updatedAt @map("updated_at")
  user                  User                @relation(fields: [id], references: [id], onDelete: Cascade)
  riders                Rider[]
  userSubscriptions     UserSubscription[]
  cancelledTrips        Trip[]              @relation("CancelledBy")
  drivers               Driver[]
  wallet                Wallet?
  payments              Payment[]
  loyaltyAccount        LoyaltyAccount?
  safetyReports         SafetyReport[]      @relation("UserSafetyReports")
  reviewedSafetyReports SafetyReport[]      @relation("ReviewedBy")
  notifications         Notification[]
  auditLogs             AuditLog[]
  driverApplications    DriverApplication[]            @relation("ApplicationApplicant")
  reviewedApplications  DriverApplication[]            @relation("ApplicationReviewer")
  driverAssignmentsMade SubscriptionDriverAssignment[] @relation("AssignedBy")
  chatBlocksReceived    ChatBlock[]                    @relation("ChatBlockUser")
  chatBlocksIssued      ChatBlock[]                    @relation("ChatBlockAdmin")
  payrollRunsGenerated  PayrollRun[]                   @relation("PayrollRunGeneratedBy")
  payrollLinesApproved  DriverPayrollLine[]            @relation("PayrollLineApprovedBy")
  promoCodesCreated     PromoCode[]                    @relation("PromoCodeCreatedBy")
  promoRedemptions      PromoCodeRedemption[]
  mapPlacesCreated      MapPlace[]                     @relation("MapPlaceCreatedBy")
  mapPlacesUpdated      MapPlace[]                     @relation("MapPlaceUpdatedBy")
  mapLocationReviews    MapLocationReview[]            @relation("MapLocationReviewedBy")
  financialReviews      Trip[]                         @relation("TripFinancialReviewer")
  tripRatingsGiven      TripRating[]                   @relation("RatingParent")
  walletTransactionsAdmin WalletTransaction[]          @relation("WalletTransactionAdmin")

  @@map("profiles")
}

model Rider {
  id                      String              @id @default(uuid())
  parentId                String              @map("parent_id")
  name                    String
  relationship            String
  school                  String?
  grade                   String?
  phone                   String?
  dateOfBirth             DateTime?           @map("date_of_birth") @db.Date
  gender                  String?
  specialNeeds            Boolean             @default(false) @map("special_needs")
  specialNeedsNotes       String?             @map("special_needs_notes") @db.Text
  medicalNotes            String?             @map("medical_notes") @db.Text
  allergies               String?             @db.Text
  pickupNotes             String?             @map("pickup_notes") @db.Text
  dropoffNotes            String?             @map("dropoff_notes") @db.Text
  emergencyContactName    String?             @map("emergency_contact_name")
  emergencyContactPhone   String?             @map("emergency_contact_phone")
  authorizedPickupPersons String?             @map("authorized_pickup_persons") @db.Text
  preferredLanguage       String?             @map("preferred_language")
  avatarUrl               String?             @map("avatar_url")
  notes                   String?             @db.Text
  isActive                Boolean             @default(true) @map("is_active")
  createdAt               DateTime            @default(now()) @map("created_at")
  updatedAt               DateTime            @updatedAt @map("updated_at")
  parent             Profile             @relation(fields: [parentId], references: [id], onDelete: Cascade)
  subscriptions      UserSubscription[]
  trips              Trip[]
  subscriptionRiders SubscriptionRider[]
  tripRatings        TripRating[]

  @@index([parentId])
  @@index([isActive])
  @@map("riders")
}

model SubscriptionPackage {
  id                String             @id @default(uuid())
  name              String
  billingCycle      String             @map("billing_cycle")
  priceSar          Decimal            @map("price_sar") @db.Decimal(10, 2)
  description       String?            @db.Text
  sortOrder         Int?               @map("sort_order")
  isActive          Boolean            @default(true) @map("is_active")
  createdAt         DateTime           @default(now()) @map("created_at")
  updatedAt         DateTime           @updatedAt @map("updated_at")
  userSubscriptions UserSubscription[]

  @@map("subscription_packages")
}

model AddOn {
  id                 String              @id @default(uuid())
  name               String
  priceSar           Decimal             @map("price_sar") @db.Decimal(10, 2)
  description        String?             @db.Text
  sortOrder          Int?                @map("sort_order")
  isActive           Boolean             @default(true) @map("is_active")
  createdAt          DateTime            @default(now()) @map("created_at")
  updatedAt          DateTime            @updatedAt @map("updated_at")
  subscriptionAddOns SubscriptionAddOn[]

  @@map("add_ons")
}

model UserSubscription {
  id                     String                 @id @default(uuid())
  userId                 String                 @map("user_id")
  riderId                String?                @map("rider_id")
  packageId              String?                @map("package_id")
  subscriptionType       String                 @map("subscription_type")
  pickupLocation         String                 @map("pickup_location") @db.Text
  dropoffLocation        String                 @map("dropoff_location") @db.Text
  pickupTime             String                 @map("pickup_time")
  returnTime             String                 @map("return_time")
  femaleDriverPreference Boolean                @default(false) @map("female_driver_preference")
  autoRenewal            Boolean                @default(true) @map("auto_renewal")
  paymentStatus          PaymentStatus          @default(PENDING) @map("payment_status")
  status                 SubscriptionStatus     @default(PENDING)
  startsOn               DateTime?              @map("starts_on") @db.Date
  endsOn                 DateTime?              @map("ends_on") @db.Date
  estimatedDistanceKm    Decimal?               @map("estimated_distance_km") @db.Decimal(8, 2)
  packagePriceSar        Decimal                @default(0.00) @map("package_price_sar") @db.Decimal(10, 2)
  addOnsPriceSar         Decimal                @default(0.00) @map("add_ons_price_sar") @db.Decimal(10, 2)
  distancePriceSar       Decimal                @default(0.00) @map("distance_price_sar") @db.Decimal(10, 2)
  extraRidersPriceSar    Decimal                @default(0.00) @map("extra_riders_price_sar") @db.Decimal(10, 2)
  finalPriceSar          Decimal                @default(0.00) @map("final_price_sar") @db.Decimal(10, 2)
  cancellationReason     String?                @map("cancellation_reason") @db.Text
  // ── Distance & route snapshot (Task 8.6) ─────────────────────────────────────
  tripDirection          TripDirection          @default(ONE_WAY) @map("trip_direction")
  oneWayDistanceKm       Decimal?               @map("one_way_distance_km") @db.Decimal(8, 2)
  chargeableDistanceKm   Decimal?               @map("chargeable_distance_km") @db.Decimal(8, 2)
  distanceProvider       String?                @map("distance_provider")
  pickupLat              Float?                 @map("pickup_lat")
  pickupLng              Float?                 @map("pickup_lng")
  dropoffLat             Float?                 @map("dropoff_lat")
  dropoffLng             Float?                 @map("dropoff_lng")
  normalizedPickupLabel  String?                @map("normalized_pickup_label") @db.Text
  normalizedDropoffLabel String?                @map("normalized_dropoff_label") @db.Text
  pickupPhotoUrl         String?                @map("pickup_photo_url")
  dropoffPhotoUrl        String?                @map("dropoff_photo_url")
  pricePerKmSarSnapshot  Decimal?               @map("price_per_km_sar_snapshot") @db.Decimal(10, 4)
  // ── Multi-day pricing snapshot (Task 11) ─────────────────────────────────────
  /// Number of actual service days in the subscription period (weekdays × weeks, minus excluded dates).
  actualServiceDays         Int?                @map("actual_service_days")
  /// Per-day chargeable distance (1× or 2× route distance depending on tripDirection).
  dailyChargeableDistanceKm Decimal?            @map("daily_chargeable_distance_km") @db.Decimal(8, 2)
  /// totalChargeableDistanceKm = dailyChargeableDistanceKm × actualServiceDays.
  totalChargeableDistanceKm Decimal?            @map("total_chargeable_distance_km") @db.Decimal(8, 2)
  // ── Enterprise driver assignment (Task 11E) ───────────────────────────────────
  /// Currently active assigned driver for this subscription (denormalised for fast trip generation).
  assignedDriverId          String?             @map("assigned_driver_id")
  /// Promo / influencer discount applied at checkout.
  promoCodeId               String?             @map("promo_code_id")
  subtotalSar               Decimal?            @map("subtotal_sar") @db.Decimal(10, 2)
  promoDiscountSar          Decimal             @default(0.00) @map("promo_discount_sar") @db.Decimal(10, 2)
  loyaltyPointsRedeemed   Int                 @default(0) @map("loyalty_points_redeemed")
  loyaltyDiscountSar      Decimal             @default(0.00) @map("loyalty_discount_sar") @db.Decimal(10, 2)
  distanceApproximate     Boolean             @default(false) @map("distance_approximate")
  createdAt              DateTime               @default(now()) @map("created_at")
  updatedAt              DateTime               @updatedAt @map("updated_at")
  user                   Profile                @relation(fields: [userId], references: [id], onDelete: Cascade)
  rider                  Rider?                 @relation(fields: [riderId], references: [id], onDelete: SetNull)
  package                SubscriptionPackage?   @relation(fields: [packageId], references: [id], onDelete: SetNull)
  assignedDriver         Driver?                @relation("SubscriptionAssignedDriver", fields: [assignedDriverId], references: [id], onDelete: SetNull)
  promoCode              PromoCode?             @relation(fields: [promoCodeId], references: [id], onDelete: SetNull)
  schedules              SubscriptionSchedule[]
  trips                  Trip[]
  payments               Payment[]
  addOns                 SubscriptionAddOn[]
  subscriptionRiders     SubscriptionRider[]
  driverAssignments      SubscriptionDriverAssignment[]
  promoRedemptions       PromoCodeRedemption[]
  mapLocationReviews     MapLocationReview[]

  @@index([userId])
  @@index([status])
  @@index([paymentStatus])
  @@index([packageId])
  @@index([assignedDriverId])
  @@index([promoCodeId])
  @@index([createdAt])
  @@map("user_subscriptions")
}

model SubscriptionSchedule {
  id             String           @id @default(uuid())
  subscriptionId String           @map("subscription_id")
  weekday        Int
  isOffDay       Boolean          @default(false) @map("is_off_day")
  createdAt      DateTime         @default(now()) @map("created_at")
  subscription   UserSubscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@index([subscriptionId])
  @@map("subscription_schedules")
}

model SubscriptionAddOn {
  id             String           @id @default(uuid())
  subscriptionId String           @map("subscription_id")
  addOnId        String           @map("add_on_id")
  createdAt      DateTime         @default(now()) @map("created_at")
  subscription   UserSubscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  addOn          AddOn            @relation(fields: [addOnId], references: [id], onDelete: Cascade)

  @@map("subscription_add_ons")
}

model SubscriptionRider {
  id              String           @id @default(uuid())
  subscriptionId  String           @map("subscription_id")
  riderId         String           @map("rider_id")
  isPrimary       Boolean          @default(false) @map("is_primary")
  priceMultiplier Decimal          @default(1.00) @map("price_multiplier") @db.Decimal(4, 2)
  createdAt       DateTime         @default(now()) @map("created_at")
  subscription    UserSubscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  rider           Rider            @relation(fields: [riderId], references: [id], onDelete: Cascade)

  @@unique([subscriptionId, riderId])
  @@map("subscription_riders")
}

/// Records the history of driver assignments for a subscription.
/// Supports mid-subscription driver changes with effectiveFrom / effectiveTo.
model SubscriptionDriverAssignment {
  id             String           @id @default(uuid())
  subscriptionId String           @map("subscription_id")
  driverId       String           @map("driver_id")
  /// Date this assignment takes effect (inclusive). Null = immediately.
  effectiveFrom  DateTime?        @map("effective_from") @db.Date
  /// Date this assignment ends (inclusive). Null = open-ended / current assignment.
  effectiveTo    DateTime?        @map("effective_to") @db.Date
  assignedBy     String?          @map("assigned_by")
  notes          String?          @db.Text
  createdAt      DateTime         @default(now()) @map("created_at")
  subscription   UserSubscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  driver         Driver           @relation("DriverAssignments", fields: [driverId], references: [id], onDelete: Cascade)
  assigner       Profile?         @relation("AssignedBy", fields: [assignedBy], references: [id], onDelete: SetNull)

  @@index([subscriptionId])
  @@index([driverId])
  @@index([effectiveFrom])
  @@map("subscription_driver_assignments")
}

model Vehicle {
  id          String   @id @default(uuid())
  model       String
  plateNumber String   @unique @map("plate_number")
  color       String?
  capacity    Int?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  drivers     Driver[]
  trips       Trip[]

  @@map("vehicles")
}

model Driver {
  id               String           @id @default(uuid())
  profileId        String?          @map("profile_id")
  vehicleId        String?          @map("vehicle_id")
  availability     Boolean          @default(true)
  rating           Decimal?         @default(5.0) @db.Decimal(2, 1)
  isSuspended      Boolean          @default(false) @map("is_suspended")
  suspensionReason String?          @map("suspension_reason") @db.Text
  /// City the driver operates in — copied from approved DriverApplication on admin approval.
  city             String?
  /// Service area(s) — free-text copied from approved DriverApplication. Used by admin for geographic assignment guidance.
  serviceArea      String?          @map("service_area")
  createdAt        DateTime         @default(now()) @map("created_at")
  updatedAt        DateTime         @updatedAt @map("updated_at")
  profile               Profile?                       @relation(fields: [profileId], references: [id], onDelete: Cascade)
  vehicle               Vehicle?                       @relation(fields: [vehicleId], references: [id], onDelete: SetNull)
  trips                 Trip[]
  locations             DriverLocation[]
  assignedSubscriptions UserSubscription[]             @relation("SubscriptionAssignedDriver")
  driverAssignments     SubscriptionDriverAssignment[] @relation("DriverAssignments")
  chatBlocks            ChatBlock[]
  payProfile            DriverPayProfile?
  tripEarnings          DriverTripEarning[]
  payrollLines          DriverPayrollLine[]
  tripRatings           TripRating[]

  @@index([profileId])
  @@index([isSuspended])
  @@index([city])
  @@map("drivers")
}

model Trip {
  id                   String              @id @default(uuid())
  subscriptionId       String?             @map("subscription_id")
  riderId              String?             @map("rider_id")
  driverId             String?             @map("driver_id")
  vehicleId            String?             @map("vehicle_id")
  scheduledDate        DateTime            @map("scheduled_date") @db.Date
  scheduledPickupTime  DateTime?           @map("scheduled_pickup_time")
  scheduledDropoffTime DateTime?           @map("scheduled_dropoff_time")
  actualPickupTime     DateTime?           @map("actual_pickup_time")
  actualDropoffTime    DateTime?           @map("actual_dropoff_time")
  pickupLocation       String              @map("pickup_location") @db.Text
  dropoffLocation      String              @map("dropoff_location") @db.Text
  /// Pickup coordinates inherited from the subscription's LocationPicker selection (Task 11H).
  pickupLat            Float?              @map("pickup_lat")
  pickupLng            Float?              @map("pickup_lng")
  /// Dropoff coordinates inherited from the subscription's LocationPicker selection (Task 11H).
  dropoffLat           Float?              @map("dropoff_lat")
  dropoffLng           Float?              @map("dropoff_lng")
  /// Admin-entered billable km when trip coordinates are missing or disputed.
  billableKmOverride   Decimal?            @map("billable_km_override") @db.Decimal(10, 3)
  status               TripStatus          @default(SCHEDULED)
  legType              TripLegType         @default(OUTBOUND) @map("leg_type")
  /// True when trip is waiting for admin dispatch (timeline infeasible for default driver).
  needsDispatch        Boolean             @default(false) @map("needs_dispatch")
  /// Why dispatch is needed (conflict detail for admin queue).
  dispatchNote         String?             @map("dispatch_note") @db.Text
  /// Optional human-readable reason for the current status (e.g. cancellation reason, delay reason, no-show reason).
  statusReason         String?             @map("status_reason") @db.Text
  cancelledBy          String?             @map("cancelled_by")
  /// UTC timestamp when the chat window was opened for this trip.
  chatOpenedAt         DateTime?           @map("chat_opened_at")
  /// UTC timestamp when the chat window was closed for this trip.
  chatClosedAt         DateTime?           @map("chat_closed_at")
  /// Admin financial review gate for stale/disputed completions (Enterprise PR 4).
  financialReviewStatus TripFinancialReviewStatus? @map("financial_review_status")
  financialReviewReason String?             @map("financial_review_reason") @db.Text
  financialReviewedAt  DateTime?           @map("financial_reviewed_at")
  financialReviewedBy  String?             @map("financial_reviewed_by")
  /// Wallet credit issued for CREDIT_PARENT financial review (idempotent link).
  walletCreditTransactionId String?            @unique @map("wallet_credit_transaction_id")
  createdAt            DateTime            @default(now()) @map("created_at")
  updatedAt            DateTime            @updatedAt @map("updated_at")
  subscription         UserSubscription?   @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
  rider                Rider?              @relation(fields: [riderId], references: [id], onDelete: SetNull)
  driver               Driver?             @relation(fields: [driverId], references: [id], onDelete: SetNull)
  vehicle              Vehicle?            @relation(fields: [vehicleId], references: [id], onDelete: SetNull)
  canceller            Profile?            @relation("CancelledBy", fields: [cancelledBy], references: [id], onDelete: SetNull)
  financialReviewer    Profile?            @relation("TripFinancialReviewer", fields: [financialReviewedBy], references: [id], onDelete: SetNull)
  walletCreditTransaction WalletTransaction? @relation("TripWalletCredit", fields: [walletCreditTransactionId], references: [id], onDelete: SetNull)
  locations            DriverLocation[]
  walletTransactions   WalletTransaction[]
  safetyReports        SafetyReport[]
  events               TripEvent[]
  chatMessages         TripChatMessage[]
  tripEarning          DriverTripEarning?

  @@index([subscriptionId])
  @@index([riderId])
  @@index([driverId])
  @@index([status])
  @@index([scheduledDate])
  @@index([legType])
  @@index([needsDispatch])
  @@unique([subscriptionId, riderId, scheduledDate, legType], map: "trips_sub_rider_date_leg_unique")
  @@index([createdAt])
  @@map("trips")
}

model DriverLocation {
  id         BigInt   @id @default(autoincrement())
  driverId   String   @map("driver_id")
  tripId     String?  @map("trip_id")
  lat        Float
  lng        Float
  recordedAt DateTime @default(now()) @map("recorded_at")
  driver     Driver   @relation(fields: [driverId], references: [id], onDelete: Cascade)
  trip       Trip?    @relation(fields: [tripId], references: [id], onDelete: SetNull)

  @@index([driverId])
  @@index([tripId])
  @@index([recordedAt])
  @@map("driver_locations")
}

model Wallet {
  id           String              @id @default(uuid())
  userId       String              @unique @map("user_id")
  balanceSar   Decimal             @default(0.00) @map("balance_sar") @db.Decimal(10, 2)
  createdAt    DateTime            @default(now()) @map("created_at")
  updatedAt    DateTime            @updatedAt @map("updated_at")
  user         Profile             @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions WalletTransaction[]

  @@map("wallets")
}

model WalletTransaction {
  id          String                @id @default(uuid())
  walletId    String                @map("wallet_id")
  tripId      String?               @map("trip_id")
  paymentId   String?               @map("payment_id")
  amountSar   Decimal               @map("amount_sar") @db.Decimal(10, 2)
  txType      WalletTransactionType @map("tx_type")
  source      WalletTransactionSource @default(MANUAL_ADJUSTMENT) @map("source")
  idempotencyKey String?            @unique @map("idempotency_key") @db.VarChar(191)
  adminUserId String?               @map("admin_user_id")
  reason      String?               @db.Text
  description String?               @db.Text
  createdAt   DateTime              @default(now()) @map("created_at")
  wallet      Wallet                @relation(fields: [walletId], references: [id], onDelete: Cascade)
  trip        Trip?                 @relation(fields: [tripId], references: [id], onDelete: SetNull)
  payment     Payment?              @relation(fields: [paymentId], references: [id], onDelete: SetNull)
  adminUser   Profile?              @relation("WalletTransactionAdmin", fields: [adminUserId], references: [id], onDelete: SetNull)
  tripWalletCredit Trip?            @relation("TripWalletCredit")

  @@index([walletId])
  @@index([createdAt])
  @@index([tripId])
  @@index([source])
  @@index([adminUserId])
  @@map("wallet_transactions")
}

model Payment {
  id                 String              @id @default(uuid())
  userId             String              @map("user_id")
  subscriptionId     String?             @map("subscription_id")
  amountSar          Decimal             @map("amount_sar") @db.Decimal(10, 2)
  status             PaymentStatus       @default(PENDING)
  purpose            PaymentPurpose      @default(SUBSCRIPTION_PAYMENT) @map("purpose")
  gateway            String?             @default("myfatoorah")
  externalRef        String?             @map("external_ref")
  invoiceId          String?             @map("invoice_id")
  paymentId          String?             @map("payment_id")
  idempotencyKey     String?             @unique @map("idempotency_key")
  /// MyFatoorah hosted payment URL stored at invoice creation — allows "Resume Payment" UX.
  invoiceUrl         String?             @map("invoice_url") @db.Text
  createdAt          DateTime            @default(now()) @map("created_at")
  updatedAt          DateTime            @updatedAt @map("updated_at")
  user               Profile             @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscription       UserSubscription?   @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
  walletTransactions WalletTransaction[]
  promoRedemptions   PromoCodeRedemption[]

  @@index([userId])
  @@index([subscriptionId])
  @@index([status])
  @@index([externalRef])
  @@index([createdAt])
  @@map("payments")
}

model LoyaltyAccount {
  id            String               @id @default(uuid())
  userId        String               @unique @map("user_id")
  pointsBalance Int                  @default(0) @map("points_balance")
  createdAt     DateTime             @default(now()) @map("created_at")
  updatedAt     DateTime             @updatedAt @map("updated_at")
  user          Profile              @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions  LoyaltyTransaction[]

  @@map("loyalty_accounts")
}

model LoyaltyTransaction {
  id             String         @id @default(uuid())
  accountId      String         @map("account_id")
  points         Int
  reason         String?
  paymentId      String?        @unique @map("payment_id")
  subscriptionId String?        @map("subscription_id")
  createdAt      DateTime       @default(now()) @map("created_at")
  account        LoyaltyAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([subscriptionId])
  @@map("loyalty_transactions")
}

model PromoCode {
  id               String                @id @default(uuid())
  code             String                @unique
  partnerName      String?               @map("partner_name")
  discountPercent  Int                   @map("discount_percent")
  maxUses          Int?                  @map("max_uses")
  useCount         Int                   @default(0) @map("use_count")
  expiresAt        DateTime?             @map("expires_at")
  isActive         Boolean               @default(true) @map("is_active")
  totalDiscountSar Decimal               @default(0.00) @map("total_discount_sar") @db.Decimal(12, 2)
  totalPaidSar     Decimal               @default(0.00) @map("total_paid_sar") @db.Decimal(12, 2)
  notes            String?               @db.Text
  createdById      String?               @map("created_by_id")
  createdAt        DateTime              @default(now()) @map("created_at")
  updatedAt        DateTime              @updatedAt @map("updated_at")
  createdBy        Profile?              @relation("PromoCodeCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  subscriptions    UserSubscription[]
  redemptions      PromoCodeRedemption[]

  @@index([isActive])
  @@index([expiresAt])
  @@map("promo_codes")
}

model PromoCodeRedemption {
  id             String            @id @default(uuid())
  promoCodeId    String            @map("promo_code_id")
  userId         String            @map("user_id")
  subscriptionId String?           @map("subscription_id")
  paymentId      String?           @map("payment_id")
  subtotalSar    Decimal           @map("subtotal_sar") @db.Decimal(10, 2)
  discountSar    Decimal           @map("discount_sar") @db.Decimal(10, 2)
  finalSar       Decimal           @map("final_sar") @db.Decimal(10, 2)
  createdAt      DateTime          @default(now()) @map("created_at")
  promoCode      PromoCode         @relation(fields: [promoCodeId], references: [id], onDelete: Cascade)
  user           Profile           @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscription   UserSubscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
  payment        Payment?          @relation(fields: [paymentId], references: [id], onDelete: SetNull)

  @@index([promoCodeId])
  @@index([userId])
  @@index([subscriptionId])
  @@map("promo_code_redemptions")
}

model SafetyReport {
  id            String                   @id @default(uuid())
  userId        String?                  @map("user_id")
  tripId        String?                  @map("trip_id")
  category      String
  description   String                   @db.Text
  status        SafetyStatus             @default(PENDING)
  adminResponse String?                  @map("admin_response") @db.Text
  reviewedBy    String?                  @map("reviewed_by")
  reviewedAt    DateTime?                @map("reviewed_at")
  createdAt     DateTime                 @default(now()) @map("created_at")
  updatedAt     DateTime                 @updatedAt @map("updated_at")
  user          Profile?                 @relation("UserSafetyReports", fields: [userId], references: [id], onDelete: SetNull)
  trip          Trip?                    @relation(fields: [tripId], references: [id], onDelete: SetNull)
  reviewer      Profile?                 @relation("ReviewedBy", fields: [reviewedBy], references: [id], onDelete: SetNull)
  attachments   SafetyReportAttachment[]

  @@index([userId])
  @@index([status])
  @@index([tripId])
  @@index([createdAt])
  @@map("safety_reports")
}

model SafetyReportAttachment {
  id        String        @id @default(uuid())
  reportId  String?       @map("report_id")
  filePath  String        @map("file_path") @db.Text
  createdAt DateTime      @default(now()) @map("created_at")
  report    SafetyReport? @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@map("safety_report_attachments")
}

model Notification {
  id        String   @id @default(uuid())
  userId    String?  @map("user_id")
  title     String
  message   String   @db.Text
  type      String
  isRead    Boolean  @default(false) @map("is_read")
  createdAt DateTime @default(now()) @map("created_at")
  user      Profile? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
  @@map("notifications")
}

model SystemConfiguration {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt @map("updated_at")
  /// Profile ID of the admin who last changed this setting — for audit purposes.
  updatedBy String?  @map("updated_by")

  @@map("system_configurations")
}

model TripGenerationLog {
  id             String   @id @default(uuid())
  runDate        DateTime @map("run_date") @db.Date
  generatedCount Int      @default(0) @map("generated_count")
  failedCount    Int      @default(0) @map("failed_count")
  notes          String?  @db.Text
  createdAt      DateTime @default(now()) @map("created_at")

  @@map("trip_generation_logs")
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?  @map("user_id")
  action    String
  details   String?  @db.Text
  ipAddress String?  @map("ip_address")
  createdAt DateTime @default(now()) @map("created_at")
  user      Profile? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}

model DriverApplication {
  id                     String                  @id @default(uuid())
  userId                 String                  @map("user_id")
  vehicleType            VehicleType             @map("vehicle_type")
  vehicleCategory        String                  @map("vehicle_category")
  vehicleBrand           String                  @map("vehicle_brand")
  vehicleModel           String                  @map("vehicle_model")
  vehicleYear            Int                     @map("vehicle_year")
  plateNumber            String                  @map("plate_number")
  vehicleColor           String                  @map("vehicle_color")
  vehicleCapacity        Int                     @map("vehicle_capacity")
  licenseNumber          String                  @map("license_number")
  driverLicenseUrl       String?                 @map("driver_license_url") @db.Text
  vehicleRegistrationUrl String?                 @map("vehicle_registration_url") @db.Text
  nationalIdUrl          String?                 @map("national_id_url") @db.Text
  vehicleInsuranceUrl    String?                 @map("vehicle_insurance_url") @db.Text
  vehiclePhotoUrl        String?                 @map("vehicle_photo_url") @db.Text
  driverNotes            String?                 @map("driver_notes") @db.Text
  city                   String
  serviceArea            String                  @map("service_area")
  femaleDriver           Boolean                 @default(false) @map("female_driver")
  status                 DriverApplicationStatus @default(PENDING)
  adminResponse          String?                 @map("admin_response") @db.Text
  reviewedBy             String?                 @map("reviewed_by")
  reviewedAt             DateTime?               @map("reviewed_at")
  submittedAt            DateTime                @default(now()) @map("submitted_at")
  resubmittedAt          DateTime?               @map("resubmitted_at")
  createdAt              DateTime                @default(now()) @map("created_at")
  updatedAt              DateTime                @updatedAt @map("updated_at")
  applicant              Profile                 @relation("ApplicationApplicant", fields: [userId], references: [id], onDelete: Cascade)
  reviewer               Profile?                @relation("ApplicationReviewer", fields: [reviewedBy], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([status])
  @@map("driver_applications")
}

/// Structured event log for a trip — used for audit trail, notification deduplication,
/// and admin debugging. One record per event type per trip (enforced by application logic).
model TripEvent {
  id          String   @id @default(cuid())
  tripId      String   @map("trip_id")
  actorUserId String?  @map("actor_user_id")
  actorRole   String?  @map("actor_role")
  /// Event type constant, e.g. "STATUS_CHANGED", "NEAR_PICKUP", "RIDER_PICKED_UP".
  eventType   String   @map("event_type")
  message     String?  @db.Text
  metadata    Json?
  createdAt   DateTime @default(now()) @map("created_at")
  trip        Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@index([tripId])
  @@index([eventType])
  @@index([createdAt])
  @@map("trip_events")
}

/// Chat message sent between parent and driver for a specific trip.
model TripChatMessage {
  id               String    @id @default(cuid())
  tripId           String    @map("trip_id")
  senderUserId     String    @map("sender_user_id")
  senderRole       String    @map("sender_role")
  /// TEXT (default) or QUICK_REPLY
  messageType      String    @default("TEXT") @map("message_type")
  body             String    @db.Text
  attachmentUrl    String?   @map("attachment_url") @db.Text
  /// CLEAN | FLAGGED | BLOCKED
  moderationStatus String    @default("CLEAN") @map("moderation_status")
  createdAt        DateTime  @default(now()) @map("created_at")
  deletedAt        DateTime? @map("deleted_at")
  trip             Trip      @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@index([tripId])
  @@index([moderationStatus])
  @@index([createdAt])
  @@map("trip_chat_messages")
}

/// Parent rating after service-day completion (one rating per rider + business date + driver).
model TripRating {
  id             String    @id @default(uuid())
  riderId        String    @map("rider_id")
  driverId       String    @map("driver_id")
  parentId       String    @map("parent_id")
  subscriptionId String?   @map("subscription_id")
  serviceDate    DateTime  @map("service_date") @db.Date
  rating         Int
  comment        String?   @db.Text
  createdAt      DateTime  @default(now()) @map("created_at")
  rider          Rider     @relation(fields: [riderId], references: [id], onDelete: Cascade)
  driver         Driver    @relation(fields: [driverId], references: [id], onDelete: Cascade)
  parent         Profile   @relation("RatingParent", fields: [parentId], references: [id], onDelete: Cascade)

  @@unique([riderId, serviceDate, driverId], map: "trip_ratings_rider_date_driver_unique")
  @@index([parentId])
  @@index([driverId])
  @@map("trip_ratings")
}

/// Admin-imposed chat restriction for safety/moderation.
model ChatBlock {
  id               String    @id @default(cuid())
  userId           String?   @map("user_id")
  driverId         String?   @map("driver_id")
  /// USER | DRIVER | GLOBAL
  targetType       String    @map("target_type")
  reason           String    @db.Text
  blockedByAdminId String    @map("blocked_by_admin_id")
  startsAt         DateTime  @default(now()) @map("starts_at")
  endsAt           DateTime? @map("ends_at")
  active           Boolean   @default(true)
  createdAt        DateTime  @default(now()) @map("created_at")
  user             Profile?  @relation("ChatBlockUser", fields: [userId], references: [id], onDelete: SetNull)
  driver           Driver?   @relation(fields: [driverId], references: [id], onDelete: SetNull)
  blockedBy        Profile   @relation("ChatBlockAdmin", fields: [blockedByAdminId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([driverId])
  @@index([active])
  @@index([targetType])
  @@map("chat_blocks")
}

enum PayrollLineStatus {
  DRAFT
  APPROVED
  PAID
}

enum KmSource {
  ROAD
  HAVERSINE
  MANUAL
}

enum SupplierPayoutStatus {
  NOT_SUBMITTED
  PENDING
  APPROVED
  REJECTED
}

enum PayrollPayoutMethod {
  MANUAL
  MYFATOORAH
}

enum MapPlaceType {
  DISTRICT
  SCHOOL
  UNIVERSITY
  MOSQUE
  HOSPITAL
  LANDMARK
  STREET
  BUILDING
  GATE
  OTHER
}

enum LocationConfidence {
  HIGH
  MEDIUM
  LOW
}

enum MapLocationKind {
  PICKUP
  DROPOFF
}

enum MapLocationReviewStatus {
  PENDING
  APPROVED
  IGNORED
  CONVERTED
}

enum MapGeocodeCacheKind {
  FORWARD
  REVERSE
}

/// Optional per-driver overrides for trip-based pay (null fields inherit global rules).
model DriverPayProfile {
  id                    String               @id @default(cuid())
  driverId              String               @unique @map("driver_id")
  ratePerKmSar          Decimal?             @map("rate_per_km_sar") @db.Decimal(10, 4)
  platformFeePercent    Decimal?             @map("platform_fee_percent") @db.Decimal(5, 2)
  bankAccountHolderName String?              @map("bank_account_holder_name")
  bankIban              String?              @map("bank_iban")
  bankAccountNumber     String?              @map("bank_account_number")
  bankId                String?              @map("bank_id")
  myfatoorahSupplierCode Int?                @map("myfatoorah_supplier_code")
  supplierStatus        SupplierPayoutStatus @default(NOT_SUBMITTED) @map("supplier_status")
  supplierStatusNote    String?              @map("supplier_status_note") @db.Text
  createdAt             DateTime             @default(now()) @map("created_at")
  updatedAt             DateTime             @updatedAt @map("updated_at")
  driver                Driver               @relation(fields: [driverId], references: [id], onDelete: Cascade)

  @@map("driver_pay_profiles")
}

/// Snapshot of pay for one completed trip — immutable once linked to a payroll line.
model DriverTripEarning {
  id                 String             @id @default(cuid())
  tripId             String             @unique @map("trip_id")
  driverId           String             @map("driver_id")
  payrollLineId      String?            @map("payroll_line_id")
  billableKm         Decimal            @map("billable_km") @db.Decimal(10, 3)
  kmSource           KmSource           @map("km_source")
  ratePerKmSar       Decimal            @map("rate_per_km_sar") @db.Decimal(10, 4)
  platformFeePercent Decimal            @map("platform_fee_percent") @db.Decimal(5, 2)
  grossSar           Decimal            @map("gross_sar") @db.Decimal(10, 2)
  platformFeeSar     Decimal            @map("platform_fee_sar") @db.Decimal(10, 2)
  netSar             Decimal            @map("net_sar") @db.Decimal(10, 2)
  tripCompletedAt    DateTime           @map("trip_completed_at")
  createdAt          DateTime           @default(now()) @map("created_at")
  trip               Trip               @relation(fields: [tripId], references: [id], onDelete: Cascade)
  driver             Driver             @relation(fields: [driverId], references: [id], onDelete: Cascade)
  payrollLine        DriverPayrollLine? @relation(fields: [payrollLineId], references: [id], onDelete: SetNull)

  @@index([driverId])
  @@index([payrollLineId])
  @@index([tripCompletedAt])
  @@map("driver_trip_earnings")
}

/// Monthly payroll batch generated by admin.
model PayrollRun {
  id               String              @id @default(cuid())
  year             Int
  month            Int
  status           String              @default("GENERATED")
  triggeredBy      String              @default("ADMIN") @map("triggered_by")
  skippedTripCount Int                 @default(0) @map("skipped_trip_count")
  skippedTrips     Json?               @map("skipped_trips")
  generatedAt      DateTime            @default(now()) @map("generated_at")
  generatedById    String?             @map("generated_by_id")
  notes            String?             @db.Text
  lines            DriverPayrollLine[]
  generatedBy      Profile?            @relation("PayrollRunGeneratedBy", fields: [generatedById], references: [id], onDelete: SetNull)

  @@unique([year, month])
  @@map("payroll_runs")
}

/// Aggregated monthly pay line for one driver.
model DriverPayrollLine {
  id              String              @id @default(cuid())
  payrollRunId    String              @map("payroll_run_id")
  driverId        String              @map("driver_id")
  tripCount       Int                 @default(0) @map("trip_count")
  totalBillableKm Decimal             @default(0) @map("total_billable_km") @db.Decimal(10, 3)
  grossSar        Decimal             @default(0) @map("gross_sar") @db.Decimal(10, 2)
  platformFeeSar  Decimal             @default(0) @map("platform_fee_sar") @db.Decimal(10, 2)
  tripNetSar      Decimal             @default(0) @map("trip_net_sar") @db.Decimal(10, 2)
  deductionsSar   Decimal             @default(0) @map("deductions_sar") @db.Decimal(10, 2)
  bonusesSar      Decimal             @default(0) @map("bonuses_sar") @db.Decimal(10, 2)
  netPaySar       Decimal             @default(0) @map("net_pay_sar") @db.Decimal(10, 2)
  status          PayrollLineStatus   @default(DRAFT)
  adminNotes      String?             @map("admin_notes") @db.Text
  paidAt          DateTime?           @map("paid_at")
  approvedAt      DateTime?           @map("approved_at")
  approvedById    String?             @map("approved_by_id")
  payoutMethod    PayrollPayoutMethod? @map("payout_method")
  payoutRef       String?             @map("payout_ref")
  payoutError     String?             @map("payout_error") @db.Text
  createdAt       DateTime            @default(now()) @map("created_at")
  updatedAt       DateTime            @updatedAt @map("updated_at")
  payrollRun      PayrollRun          @relation(fields: [payrollRunId], references: [id], onDelete: Cascade)
  driver          Driver              @relation(fields: [driverId], references: [id], onDelete: Cascade)
  tripEarnings    DriverTripEarning[]
  approvedBy      Profile?            @relation("PayrollLineApprovedBy", fields: [approvedById], references: [id], onDelete: SetNull)

  @@unique([payrollRunId, driverId])
  @@index([driverId])
  @@index([status])
  @@map("driver_payroll_lines")
}

model MapPlace {
  id                    String       @id @default(uuid())
  nameAr                String       @map("name_ar")
  nameEn                String       @map("name_en")
  type                  MapPlaceType
  city                  String
  region                String?
  country               String       @default("SA")
  latitude              Decimal      @db.Decimal(10, 7)
  longitude             Decimal      @db.Decimal(10, 7)
  aliasesAr             Json         @default("[]") @map("aliases_ar")
  aliasesEn             Json         @default("[]") @map("aliases_en")
  normalizedNameAr      String       @default("") @map("normalized_name_ar") @db.VarChar(300)
  normalizedNameEn      String       @default("") @map("normalized_name_en") @db.VarChar(300)
  normalizedAliasesAr   String       @default("") @map("normalized_aliases_ar") @db.VarChar(2000)
  normalizedAliasesEn   String       @default("") @map("normalized_aliases_en") @db.VarChar(2000)
  isActive              Boolean      @default(true) @map("is_active")
  isVerified            Boolean      @default(false) @map("is_verified")
  notes                 String?      @db.Text
  createdById           String?      @map("created_by_id")
  updatedById           String?      @map("updated_by_id")
  createdAt             DateTime     @default(now()) @map("created_at")
  updatedAt             DateTime     @updatedAt @map("updated_at")
  createdBy             Profile?     @relation("MapPlaceCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy             Profile?     @relation("MapPlaceUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  convertedFromReviews  MapLocationReview[] @relation("ReviewConvertedPlace")

  @@index([city])
  @@index([type])
  @@index([isActive])
  @@index([isVerified])
  @@index([normalizedNameAr])
  @@index([normalizedNameEn])
  @@index([latitude, longitude])
  @@map("map_places")
}

model MapGeocodeCache {
  id              String              @id @default(uuid())
  kind            MapGeocodeCacheKind
  query           String?             @db.VarChar(500)
  normalizedQuery String?             @map("normalized_query") @db.VarChar(500)
  language        String              @default("en")
  roundedLat      Decimal?            @map("rounded_lat") @db.Decimal(8, 5)
  roundedLng      Decimal?            @map("rounded_lng") @db.Decimal(8, 5)
  provider        String              @db.VarChar(32)
  resultJson      Json                @map("result_json")
  expiresAt       DateTime            @map("expires_at")
  createdAt       DateTime            @default(now()) @map("created_at")

  @@index([kind, normalizedQuery, language, provider])
  @@index([kind, roundedLat, roundedLng, language, provider])
  @@index([expiresAt])
  @@map("map_geocode_cache")
}

model MapLocationReview {
  id                  String                  @id @default(uuid())
  subscriptionId      String?                 @map("subscription_id")
  locationKind        MapLocationKind         @map("location_kind")
  label               String                  @db.Text
  latitude            Decimal                 @db.Decimal(10, 7)
  longitude           Decimal                 @db.Decimal(10, 7)
  source              String                  @db.VarChar(32)
  confidence          LocationConfidence
  placeId             String?                 @map("place_id")
  status              MapLocationReviewStatus @default(PENDING)
  convertedMapPlaceId String?                 @map("converted_map_place_id")
  reviewedById        String?                 @map("reviewed_by_id")
  adminNotes          String?                 @map("admin_notes") @db.Text
  createdAt           DateTime                @default(now()) @map("created_at")
  updatedAt           DateTime                @updatedAt @map("updated_at")
  subscription        UserSubscription?       @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
  convertedMapPlace   MapPlace?               @relation("ReviewConvertedPlace", fields: [convertedMapPlaceId], references: [id], onDelete: SetNull)
  reviewedBy          Profile?                @relation("MapLocationReviewedBy", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([confidence])
  @@index([subscriptionId])
  @@map("map_location_reviews")
}
