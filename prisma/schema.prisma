datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum UserRole {
  PARENT
  RIDER
  DRIVER
  ADMIN
}

enum SubscriptionStatus {
  PENDING
  ACTIVE
  PAUSED
  EXPIRED
  CANCELLED
}

enum TripStatus {
  SCHEDULED
  DRIVER_ASSIGNED
  /// Driver started pre-trip location sharing (within 10 min of pickup)
  PRE_TRIP
  /// Driver en route to pickup location
  ON_THE_WAY
  /// Driver has arrived at the pickup location
  ARRIVED_PICKUP
  /// Rider has been picked up
  PICKED_UP
  /// Driver en route to drop-off location
  EN_ROUTE_DROPOFF
  /// Driver has arrived at the drop-off location
  ARRIVED_DROPOFF
  COMPLETED
  CANCELLED
  /// Rider did not show at pickup
  NO_SHOW
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum SafetyStatus {
  PENDING
  APPROVED
  RESOLVED
  REJECTED
}

enum VehicleType {
  ECONOMY
  COMFORT
  FAMILY
  VAN
  BUS
  PREMIUM
}

enum DriverApplicationStatus {
  PENDING
  APPROVED
  REJECTED
  NEEDS_CHANGES
}

enum TripDirection {
  ONE_WAY
  ROUND_TRIP
}

enum TripLegType {
  OUTBOUND
  RETURN
}

enum PaymentPurpose {
  WALLET_TOP_UP
  SUBSCRIPTION_PAYMENT
}

enum WalletTransactionType {
  CREDIT
  DEBIT
  REFUND
  TOP_UP
  SUBSCRIPTION_PAYMENT
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  role         UserRole @default(PARENT)
  createdAt    DateTime @default(now()) @map("created_at")
  profile      Profile?

  @@map("users")
}

model Profile {
  id                    String              @id
  role                  UserRole            @default(PARENT)
  fullName              String              @map("full_name")
  phone                 String?
  avatarUrl             String?             @map("avatar_url") @db.Text
  /// "FAMILY" (default) or "DRIVER_PORTAL" — set at registration to separate
  /// normal family accounts from driver applicant accounts.
  /// Migration required: ALTER TABLE profiles ADD COLUMN registration_source VARCHAR(32) NOT NULL DEFAULT 'FAMILY'
  registrationSource    String              @default("FAMILY") @map("registration_source")
  createdAt             DateTime            @default(now()) @map("created_at")
  updatedAt             DateTime            @updatedAt @map("updated_at")
  user                  User                @relation(fields: [id], references: [id], onDelete: Cascade)
  riders                Rider[]
  userSubscriptions     UserSubscription[]
  cancelledTrips        Trip[]              @relation("CancelledBy")
  drivers               Driver[]
  wallet                Wallet?
  payments              Payment[]
  loyaltyAccount        LoyaltyAccount?
  safetyReports         SafetyReport[]      @relation("UserSafetyReports")
  reviewedSafetyReports SafetyReport[]      @relation("ReviewedBy")
  notifications         Notification[]
  auditLogs             AuditLog[]
  driverApplications    DriverApplication[]            @relation("ApplicationApplicant")
  reviewedApplications  DriverApplication[]            @relation("ApplicationReviewer")
  driverAssignmentsMade SubscriptionDriverAssignment[] @relation("AssignedBy")
  chatBlocksReceived    ChatBlock[]                    @relation("ChatBlockUser")
  chatBlocksIssued      ChatBlock[]                    @relation("ChatBlockAdmin")

  @@map("profiles")
}

model Rider {
  id                 String              @id @default(uuid())
  parentId           String              @map("parent_id")
  name               String
  relationship       String
  school             String?
  grade              String?
  phone              String?
  specialNeeds       Boolean             @default(false) @map("special_needs")
  notes              String?             @db.Text
  isActive           Boolean             @default(true) @map("is_active")
  createdAt          DateTime            @default(now()) @map("created_at")
  updatedAt          DateTime            @updatedAt @map("updated_at")
  parent             Profile             @relation(fields: [parentId], references: [id], onDelete: Cascade)
  subscriptions      UserSubscription[]
  trips              Trip[]
  subscriptionRiders SubscriptionRider[]

  @@index([parentId])
  @@index([isActive])
  @@map("riders")
}

model SubscriptionPackage {
  id                String             @id @default(uuid())
  name              String
  billingCycle      String             @map("billing_cycle")
  priceSar          Decimal            @map("price_sar") @db.Decimal(10, 2)
  description       String?            @db.Text
  sortOrder         Int?               @map("sort_order")
  isActive          Boolean            @default(true) @map("is_active")
  createdAt         DateTime           @default(now()) @map("created_at")
  updatedAt         DateTime           @updatedAt @map("updated_at")
  userSubscriptions UserSubscription[]

  @@map("subscription_packages")
}

model AddOn {
  id                 String              @id @default(uuid())
  name               String
  priceSar           Decimal             @map("price_sar") @db.Decimal(10, 2)
  description        String?             @db.Text
  sortOrder          Int?                @map("sort_order")
  isActive           Boolean             @default(true) @map("is_active")
  createdAt          DateTime            @default(now()) @map("created_at")
  updatedAt          DateTime            @updatedAt @map("updated_at")
  subscriptionAddOns SubscriptionAddOn[]

  @@map("add_ons")
}

model UserSubscription {
  id                     String                 @id @default(uuid())
  userId                 String                 @map("user_id")
  riderId                String?                @map("rider_id")
  packageId              String?                @map("package_id")
  subscriptionType       String                 @map("subscription_type")
  pickupLocation         String                 @map("pickup_location") @db.Text
  dropoffLocation        String                 @map("dropoff_location") @db.Text
  pickupTime             String                 @map("pickup_time")
  returnTime             String                 @map("return_time")
  femaleDriverPreference Boolean                @default(false) @map("female_driver_preference")
  autoRenewal            Boolean                @default(true) @map("auto_renewal")
  paymentStatus          PaymentStatus          @default(PENDING) @map("payment_status")
  status                 SubscriptionStatus     @default(PENDING)
  startsOn               DateTime?              @map("starts_on") @db.Date
  endsOn                 DateTime?              @map("ends_on") @db.Date
  estimatedDistanceKm    Decimal?               @map("estimated_distance_km") @db.Decimal(8, 2)
  packagePriceSar        Decimal                @default(0.00) @map("package_price_sar") @db.Decimal(10, 2)
  addOnsPriceSar         Decimal                @default(0.00) @map("add_ons_price_sar") @db.Decimal(10, 2)
  distancePriceSar       Decimal                @default(0.00) @map("distance_price_sar") @db.Decimal(10, 2)
  extraRidersPriceSar    Decimal                @default(0.00) @map("extra_riders_price_sar") @db.Decimal(10, 2)
  finalPriceSar          Decimal                @default(0.00) @map("final_price_sar") @db.Decimal(10, 2)
  cancellationReason     String?                @map("cancellation_reason") @db.Text
  // ── Distance & route snapshot (Task 8.6) ─────────────────────────────────────
  tripDirection          TripDirection          @default(ONE_WAY) @map("trip_direction")
  oneWayDistanceKm       Decimal?               @map("one_way_distance_km") @db.Decimal(8, 2)
  chargeableDistanceKm   Decimal?               @map("chargeable_distance_km") @db.Decimal(8, 2)
  distanceProvider       String?                @map("distance_provider")
  pickupLat              Float?                 @map("pickup_lat")
  pickupLng              Float?                 @map("pickup_lng")
  dropoffLat             Float?                 @map("dropoff_lat")
  dropoffLng             Float?                 @map("dropoff_lng")
  normalizedPickupLabel  String?                @map("normalized_pickup_label") @db.Text
  normalizedDropoffLabel String?                @map("normalized_dropoff_label") @db.Text
  pricePerKmSarSnapshot  Decimal?               @map("price_per_km_sar_snapshot") @db.Decimal(10, 4)
  // ── Multi-day pricing snapshot (Task 11) ─────────────────────────────────────
  /// Number of actual service days in the subscription period (weekdays × weeks, minus excluded dates).
  actualServiceDays         Int?                @map("actual_service_days")
  /// Per-day chargeable distance (1× or 2× route distance depending on tripDirection).
  dailyChargeableDistanceKm Decimal?            @map("daily_chargeable_distance_km") @db.Decimal(8, 2)
  /// totalChargeableDistanceKm = dailyChargeableDistanceKm × actualServiceDays.
  totalChargeableDistanceKm Decimal?            @map("total_chargeable_distance_km") @db.Decimal(8, 2)
  // ── Enterprise driver assignment (Task 11E) ───────────────────────────────────
  /// Currently active assigned driver for this subscription (denormalised for fast trip generation).
  assignedDriverId          String?             @map("assigned_driver_id")
  createdAt              DateTime               @default(now()) @map("created_at")
  updatedAt              DateTime               @updatedAt @map("updated_at")
  user                   Profile                @relation(fields: [userId], references: [id], onDelete: Cascade)
  rider                  Rider?                 @relation(fields: [riderId], references: [id], onDelete: SetNull)
  package                SubscriptionPackage?   @relation(fields: [packageId], references: [id], onDelete: SetNull)
  assignedDriver         Driver?                @relation("SubscriptionAssignedDriver", fields: [assignedDriverId], references: [id], onDelete: SetNull)
  schedules              SubscriptionSchedule[]
  trips                  Trip[]
  payments               Payment[]
  addOns                 SubscriptionAddOn[]
  subscriptionRiders     SubscriptionRider[]
  driverAssignments      SubscriptionDriverAssignment[]

  @@index([userId])
  @@index([status])
  @@index([paymentStatus])
  @@index([packageId])
  @@index([assignedDriverId])
  @@index([createdAt])
  @@map("user_subscriptions")
}

model SubscriptionSchedule {
  id             String           @id @default(uuid())
  subscriptionId String           @map("subscription_id")
  weekday        Int
  isOffDay       Boolean          @default(false) @map("is_off_day")
  createdAt      DateTime         @default(now()) @map("created_at")
  subscription   UserSubscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@index([subscriptionId])
  @@map("subscription_schedules")
}

model SubscriptionAddOn {
  id             String           @id @default(uuid())
  subscriptionId String           @map("subscription_id")
  addOnId        String           @map("add_on_id")
  createdAt      DateTime         @default(now()) @map("created_at")
  subscription   UserSubscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  addOn          AddOn            @relation(fields: [addOnId], references: [id], onDelete: Cascade)

  @@map("subscription_add_ons")
}

model SubscriptionRider {
  id              String           @id @default(uuid())
  subscriptionId  String           @map("subscription_id")
  riderId         String           @map("rider_id")
  isPrimary       Boolean          @default(false) @map("is_primary")
  priceMultiplier Decimal          @default(1.00) @map("price_multiplier") @db.Decimal(4, 2)
  createdAt       DateTime         @default(now()) @map("created_at")
  subscription    UserSubscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  rider           Rider            @relation(fields: [riderId], references: [id], onDelete: Cascade)

  @@unique([subscriptionId, riderId])
  @@map("subscription_riders")
}

/// Records the history of driver assignments for a subscription.
/// Supports mid-subscription driver changes with effectiveFrom / effectiveTo.
model SubscriptionDriverAssignment {
  id             String           @id @default(uuid())
  subscriptionId String           @map("subscription_id")
  driverId       String           @map("driver_id")
  /// Date this assignment takes effect (inclusive). Null = immediately.
  effectiveFrom  DateTime?        @map("effective_from") @db.Date
  /// Date this assignment ends (inclusive). Null = open-ended / current assignment.
  effectiveTo    DateTime?        @map("effective_to") @db.Date
  assignedBy     String?          @map("assigned_by")
  notes          String?          @db.Text
  createdAt      DateTime         @default(now()) @map("created_at")
  subscription   UserSubscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  driver         Driver           @relation("DriverAssignments", fields: [driverId], references: [id], onDelete: Cascade)
  assigner       Profile?         @relation("AssignedBy", fields: [assignedBy], references: [id], onDelete: SetNull)

  @@index([subscriptionId])
  @@index([driverId])
  @@index([effectiveFrom])
  @@map("subscription_driver_assignments")
}

model Vehicle {
  id          String   @id @default(uuid())
  model       String
  plateNumber String   @unique @map("plate_number")
  color       String?
  capacity    Int?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  drivers     Driver[]
  trips       Trip[]

  @@map("vehicles")
}

model Driver {
  id               String           @id @default(uuid())
  profileId        String?          @map("profile_id")
  vehicleId        String?          @map("vehicle_id")
  availability     Boolean          @default(true)
  rating           Decimal?         @default(5.0) @db.Decimal(2, 1)
  isSuspended      Boolean          @default(false) @map("is_suspended")
  suspensionReason String?          @map("suspension_reason") @db.Text
  createdAt        DateTime         @default(now()) @map("created_at")
  updatedAt        DateTime         @updatedAt @map("updated_at")
  profile               Profile?                       @relation(fields: [profileId], references: [id], onDelete: Cascade)
  vehicle               Vehicle?                       @relation(fields: [vehicleId], references: [id], onDelete: SetNull)
  trips                 Trip[]
  locations             DriverLocation[]
  assignedSubscriptions UserSubscription[]             @relation("SubscriptionAssignedDriver")
  driverAssignments     SubscriptionDriverAssignment[] @relation("DriverAssignments")
  chatBlocks            ChatBlock[]

  @@index([profileId])
  @@index([isSuspended])
  @@map("drivers")
}

model Trip {
  id                   String              @id @default(uuid())
  subscriptionId       String?             @map("subscription_id")
  riderId              String?             @map("rider_id")
  driverId             String?             @map("driver_id")
  vehicleId            String?             @map("vehicle_id")
  scheduledDate        DateTime            @map("scheduled_date") @db.Date
  scheduledPickupTime  DateTime?           @map("scheduled_pickup_time")
  scheduledDropoffTime DateTime?           @map("scheduled_dropoff_time")
  actualPickupTime     DateTime?           @map("actual_pickup_time")
  actualDropoffTime    DateTime?           @map("actual_dropoff_time")
  pickupLocation       String              @map("pickup_location") @db.Text
  dropoffLocation      String              @map("dropoff_location") @db.Text
  /// Pickup coordinates inherited from the subscription's LocationPicker selection (Task 11H).
  pickupLat            Float?              @map("pickup_lat")
  pickupLng            Float?              @map("pickup_lng")
  /// Dropoff coordinates inherited from the subscription's LocationPicker selection (Task 11H).
  dropoffLat           Float?              @map("dropoff_lat")
  dropoffLng           Float?              @map("dropoff_lng")
  status               TripStatus          @default(SCHEDULED)
  legType              TripLegType         @default(OUTBOUND) @map("leg_type")
  /// Optional human-readable reason for the current status (e.g. cancellation reason, delay reason, no-show reason).
  statusReason         String?             @map("status_reason") @db.Text
  cancelledBy          String?             @map("cancelled_by")
  /// UTC timestamp when the chat window was opened for this trip.
  chatOpenedAt         DateTime?           @map("chat_opened_at")
  /// UTC timestamp when the chat window was closed for this trip.
  chatClosedAt         DateTime?           @map("chat_closed_at")
  createdAt            DateTime            @default(now()) @map("created_at")
  updatedAt            DateTime            @updatedAt @map("updated_at")
  subscription         UserSubscription?   @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
  rider                Rider?              @relation(fields: [riderId], references: [id], onDelete: SetNull)
  driver               Driver?             @relation(fields: [driverId], references: [id], onDelete: SetNull)
  vehicle              Vehicle?            @relation(fields: [vehicleId], references: [id], onDelete: SetNull)
  canceller            Profile?            @relation("CancelledBy", fields: [cancelledBy], references: [id], onDelete: SetNull)
  locations            DriverLocation[]
  walletTransactions   WalletTransaction[]
  safetyReports        SafetyReport[]
  events               TripEvent[]
  chatMessages         TripChatMessage[]

  @@index([subscriptionId])
  @@index([riderId])
  @@index([driverId])
  @@index([status])
  @@index([scheduledDate])
  @@index([legType])
  @@index([createdAt])
  @@map("trips")
}

model DriverLocation {
  id         BigInt   @id @default(autoincrement())
  driverId   String   @map("driver_id")
  tripId     String?  @map("trip_id")
  lat        Float
  lng        Float
  recordedAt DateTime @default(now()) @map("recorded_at")
  driver     Driver   @relation(fields: [driverId], references: [id], onDelete: Cascade)
  trip       Trip?    @relation(fields: [tripId], references: [id], onDelete: SetNull)

  @@index([driverId])
  @@index([tripId])
  @@index([recordedAt])
  @@map("driver_locations")
}

model Wallet {
  id           String              @id @default(uuid())
  userId       String              @unique @map("user_id")
  balanceSar   Decimal             @default(0.00) @map("balance_sar") @db.Decimal(10, 2)
  createdAt    DateTime            @default(now()) @map("created_at")
  updatedAt    DateTime            @updatedAt @map("updated_at")
  user         Profile             @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions WalletTransaction[]

  @@map("wallets")
}

model WalletTransaction {
  id          String                @id @default(uuid())
  walletId    String                @map("wallet_id")
  tripId      String?               @map("trip_id")
  paymentId   String?               @map("payment_id")
  amountSar   Decimal               @map("amount_sar") @db.Decimal(10, 2)
  txType      WalletTransactionType @map("tx_type")
  description String?               @db.Text
  createdAt   DateTime              @default(now()) @map("created_at")
  wallet      Wallet                @relation(fields: [walletId], references: [id], onDelete: Cascade)
  trip        Trip?                 @relation(fields: [tripId], references: [id], onDelete: SetNull)
  payment     Payment?              @relation(fields: [paymentId], references: [id], onDelete: SetNull)

  @@index([walletId])
  @@index([createdAt])
  @@map("wallet_transactions")
}

model Payment {
  id                 String              @id @default(uuid())
  userId             String              @map("user_id")
  subscriptionId     String?             @map("subscription_id")
  amountSar          Decimal             @map("amount_sar") @db.Decimal(10, 2)
  status             PaymentStatus       @default(PENDING)
  purpose            PaymentPurpose      @default(SUBSCRIPTION_PAYMENT) @map("purpose")
  gateway            String?             @default("myfatoorah")
  externalRef        String?             @map("external_ref")
  invoiceId          String?             @map("invoice_id")
  paymentId          String?             @map("payment_id")
  idempotencyKey     String?             @unique @map("idempotency_key")
  /// MyFatoorah hosted payment URL stored at invoice creation — allows "Resume Payment" UX.
  invoiceUrl         String?             @map("invoice_url") @db.Text
  createdAt          DateTime            @default(now()) @map("created_at")
  updatedAt          DateTime            @updatedAt @map("updated_at")
  user               Profile             @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscription       UserSubscription?   @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
  walletTransactions WalletTransaction[]

  @@index([userId])
  @@index([subscriptionId])
  @@index([status])
  @@index([externalRef])
  @@index([createdAt])
  @@map("payments")
}

model LoyaltyAccount {
  id            String               @id @default(uuid())
  userId        String               @unique @map("user_id")
  pointsBalance Int                  @default(0) @map("points_balance")
  createdAt     DateTime             @default(now()) @map("created_at")
  updatedAt     DateTime             @updatedAt @map("updated_at")
  user          Profile              @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions  LoyaltyTransaction[]

  @@map("loyalty_accounts")
}

model LoyaltyTransaction {
  id        String         @id @default(uuid())
  accountId String         @map("account_id")
  points    Int
  reason    String?
  createdAt DateTime       @default(now()) @map("created_at")
  account   LoyaltyAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@map("loyalty_transactions")
}

model SafetyReport {
  id            String                   @id @default(uuid())
  userId        String?                  @map("user_id")
  tripId        String?                  @map("trip_id")
  category      String
  description   String                   @db.Text
  status        SafetyStatus             @default(PENDING)
  adminResponse String?                  @map("admin_response") @db.Text
  reviewedBy    String?                  @map("reviewed_by")
  reviewedAt    DateTime?                @map("reviewed_at")
  createdAt     DateTime                 @default(now()) @map("created_at")
  updatedAt     DateTime                 @updatedAt @map("updated_at")
  user          Profile?                 @relation("UserSafetyReports", fields: [userId], references: [id], onDelete: SetNull)
  trip          Trip?                    @relation(fields: [tripId], references: [id], onDelete: SetNull)
  reviewer      Profile?                 @relation("ReviewedBy", fields: [reviewedBy], references: [id], onDelete: SetNull)
  attachments   SafetyReportAttachment[]

  @@index([userId])
  @@index([status])
  @@index([tripId])
  @@index([createdAt])
  @@map("safety_reports")
}

model SafetyReportAttachment {
  id        String        @id @default(uuid())
  reportId  String?       @map("report_id")
  filePath  String        @map("file_path") @db.Text
  createdAt DateTime      @default(now()) @map("created_at")
  report    SafetyReport? @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@map("safety_report_attachments")
}

model Notification {
  id        String   @id @default(uuid())
  userId    String?  @map("user_id")
  title     String
  message   String   @db.Text
  type      String
  isRead    Boolean  @default(false) @map("is_read")
  createdAt DateTime @default(now()) @map("created_at")
  user      Profile? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
  @@map("notifications")
}

model SystemConfiguration {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("system_configurations")
}

model TripGenerationLog {
  id             String   @id @default(uuid())
  runDate        DateTime @map("run_date") @db.Date
  generatedCount Int      @default(0) @map("generated_count")
  failedCount    Int      @default(0) @map("failed_count")
  notes          String?  @db.Text
  createdAt      DateTime @default(now()) @map("created_at")

  @@map("trip_generation_logs")
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?  @map("user_id")
  action    String
  details   String?  @db.Text
  ipAddress String?  @map("ip_address")
  createdAt DateTime @default(now()) @map("created_at")
  user      Profile? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}

model DriverApplication {
  id                     String                  @id @default(uuid())
  userId                 String                  @map("user_id")
  vehicleType            VehicleType             @map("vehicle_type")
  vehicleCategory        String                  @map("vehicle_category")
  vehicleBrand           String                  @map("vehicle_brand")
  vehicleModel           String                  @map("vehicle_model")
  vehicleYear            Int                     @map("vehicle_year")
  plateNumber            String                  @map("plate_number")
  vehicleColor           String                  @map("vehicle_color")
  vehicleCapacity        Int                     @map("vehicle_capacity")
  licenseNumber          String                  @map("license_number")
  driverLicenseUrl       String?                 @map("driver_license_url") @db.Text
  vehicleRegistrationUrl String?                 @map("vehicle_registration_url") @db.Text
  nationalIdUrl          String?                 @map("national_id_url") @db.Text
  driverNotes            String?                 @map("driver_notes") @db.Text
  city                   String
  serviceArea            String                  @map("service_area")
  femaleDriver           Boolean                 @default(false) @map("female_driver")
  status                 DriverApplicationStatus @default(PENDING)
  adminResponse          String?                 @map("admin_response") @db.Text
  reviewedBy             String?                 @map("reviewed_by")
  reviewedAt             DateTime?               @map("reviewed_at")
  submittedAt            DateTime                @default(now()) @map("submitted_at")
  resubmittedAt          DateTime?               @map("resubmitted_at")
  createdAt              DateTime                @default(now()) @map("created_at")
  updatedAt              DateTime                @updatedAt @map("updated_at")
  applicant              Profile                 @relation("ApplicationApplicant", fields: [userId], references: [id], onDelete: Cascade)
  reviewer               Profile?                @relation("ApplicationReviewer", fields: [reviewedBy], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([status])
  @@map("driver_applications")
}

/// Structured event log for a trip — used for audit trail, notification deduplication,
/// and admin debugging. One record per event type per trip (enforced by application logic).
model TripEvent {
  id          String   @id @default(cuid())
  tripId      String   @map("trip_id")
  actorUserId String?  @map("actor_user_id")
  actorRole   String?  @map("actor_role")
  /// Event type constant, e.g. "STATUS_CHANGED", "NEAR_PICKUP", "RIDER_PICKED_UP".
  eventType   String   @map("event_type")
  message     String?  @db.Text
  metadata    Json?
  createdAt   DateTime @default(now()) @map("created_at")
  trip        Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@index([tripId])
  @@index([eventType])
  @@index([createdAt])
  @@map("trip_events")
}

/// Chat message sent between parent and driver for a specific trip.
model TripChatMessage {
  id               String    @id @default(cuid())
  tripId           String    @map("trip_id")
  senderUserId     String    @map("sender_user_id")
  senderRole       String    @map("sender_role")
  /// TEXT (default) or QUICK_REPLY
  messageType      String    @default("TEXT") @map("message_type")
  body             String    @db.Text
  attachmentUrl    String?   @map("attachment_url") @db.Text
  /// CLEAN | FLAGGED | BLOCKED
  moderationStatus String    @default("CLEAN") @map("moderation_status")
  createdAt        DateTime  @default(now()) @map("created_at")
  deletedAt        DateTime? @map("deleted_at")
  trip             Trip      @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@index([tripId])
  @@index([moderationStatus])
  @@index([createdAt])
  @@map("trip_chat_messages")
}

/// Admin-imposed chat restriction for safety/moderation.
model ChatBlock {
  id               String    @id @default(cuid())
  userId           String?   @map("user_id")
  driverId         String?   @map("driver_id")
  /// USER | DRIVER | GLOBAL
  targetType       String    @map("target_type")
  reason           String    @db.Text
  blockedByAdminId String    @map("blocked_by_admin_id")
  startsAt         DateTime  @default(now()) @map("starts_at")
  endsAt           DateTime? @map("ends_at")
  active           Boolean   @default(true)
  createdAt        DateTime  @default(now()) @map("created_at")
  user             Profile?  @relation("ChatBlockUser", fields: [userId], references: [id], onDelete: SetNull)
  driver           Driver?   @relation(fields: [driverId], references: [id], onDelete: SetNull)
  blockedBy        Profile   @relation("ChatBlockAdmin", fields: [blockedByAdminId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([driverId])
  @@index([active])
  @@index([targetType])
  @@map("chat_blocks")
}
