datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum UserRole {
  PARENT
  RIDER
  DRIVER
  ADMIN
}

enum SubscriptionStatus {
  PENDING
  ACTIVE
  PAUSED
  EXPIRED
  CANCELLED
}

enum TripStatus {
  SCHEDULED
  DRIVER_ASSIGNED
  ON_THE_WAY
  PICKED_UP
  COMPLETED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum SafetyStatus {
  PENDING
  APPROVED
  RESOLVED
  REJECTED
}

enum VehicleType {
  ECONOMY
  COMFORT
  FAMILY
  VAN
  BUS
  PREMIUM
}

enum DriverApplicationStatus {
  PENDING
  APPROVED
  REJECTED
  NEEDS_CHANGES
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  role         UserRole @default(PARENT)
  createdAt    DateTime @default(now()) @map("created_at")
  profile      Profile?

  @@map("users")
}

model Profile {
  id                    String             @id
  role                  UserRole           @default(PARENT)
  fullName              String             @map("full_name")
  phone                 String?
  avatarUrl             String?            @map("avatar_url") @db.Text
  createdAt             DateTime           @default(now()) @map("created_at")
  updatedAt             DateTime           @updatedAt @map("updated_at")
  user                  User               @relation(fields: [id], references: [id], onDelete: Cascade)
  riders                Rider[]
  userSubscriptions     UserSubscription[]
  cancelledTrips        Trip[]             @relation("CancelledBy")
  drivers               Driver[]
  wallet                Wallet?
  payments              Payment[]
  loyaltyAccount        LoyaltyAccount?
  safetyReports         SafetyReport[]     @relation("UserSafetyReports")
  reviewedSafetyReports SafetyReport[]     @relation("ReviewedBy")
  notifications            Notification[]
  auditLogs                AuditLog[]
  driverApplications       DriverApplication[] @relation("ApplicationApplicant")
  reviewedApplications     DriverApplication[] @relation("ApplicationReviewer")

  @@map("profiles")
}

model Rider {
  id            String             @id @default(uuid())
  parentId      String             @map("parent_id")
  name          String
  relationship  String
  school        String?
  grade         String?
  phone         String?
  specialNeeds  Boolean            @default(false) @map("special_needs")
  notes         String?            @db.Text
  isActive      Boolean            @default(true) @map("is_active")
  createdAt     DateTime           @default(now()) @map("created_at")
  updatedAt     DateTime           @updatedAt @map("updated_at")
  parent        Profile            @relation(fields: [parentId], references: [id], onDelete: Cascade)
  subscriptions UserSubscription[]
  trips         Trip[]

  @@map("riders")
}

model SubscriptionPackage {
  id                String             @id @default(uuid())
  name              String
  billingCycle      String             @map("billing_cycle")
  priceSar          Decimal            @map("price_sar") @db.Decimal(10, 2)
  description       String?            @db.Text
  isActive          Boolean            @default(true) @map("is_active")
  createdAt         DateTime           @default(now()) @map("created_at")
  updatedAt         DateTime           @updatedAt @map("updated_at")
  userSubscriptions UserSubscription[]

  @@map("subscription_packages")
}

model AddOn {
  id                 String              @id @default(uuid())
  name               String
  priceSar           Decimal             @map("price_sar") @db.Decimal(10, 2)
  isActive           Boolean             @default(true) @map("is_active")
  createdAt          DateTime            @default(now()) @map("created_at")
  updatedAt          DateTime            @updatedAt @map("updated_at")
  subscriptionAddOns SubscriptionAddOn[]

  @@map("add_ons")
}

model UserSubscription {
  id                     String                 @id @default(uuid())
  userId                 String                 @map("user_id")
  riderId                String?                @map("rider_id")
  packageId              String?                @map("package_id")
  subscriptionType       String                 @map("subscription_type")
  pickupLocation         String                 @map("pickup_location") @db.Text
  dropoffLocation        String                 @map("dropoff_location") @db.Text
  pickupTime             String                 @map("pickup_time")
  returnTime             String                 @map("return_time")
  femaleDriverPreference Boolean                @default(false) @map("female_driver_preference")
  autoRenewal            Boolean                @default(true) @map("auto_renewal")
  paymentStatus          PaymentStatus          @default(PENDING) @map("payment_status")
  status                 SubscriptionStatus     @default(PENDING)
  startsOn               DateTime?              @map("starts_on") @db.Date
  endsOn                 DateTime?              @map("ends_on") @db.Date
  createdAt              DateTime               @default(now()) @map("created_at")
  updatedAt              DateTime               @updatedAt @map("updated_at")
  user                   Profile                @relation(fields: [userId], references: [id], onDelete: Cascade)
  rider                  Rider?                 @relation(fields: [riderId], references: [id], onDelete: SetNull)
  package                SubscriptionPackage?   @relation(fields: [packageId], references: [id], onDelete: SetNull)
  schedules              SubscriptionSchedule[]
  trips                  Trip[]
  payments               Payment[]
  addOns                 SubscriptionAddOn[]

  @@map("user_subscriptions")
}

model SubscriptionSchedule {
  id             String           @id @default(uuid())
  subscriptionId String           @map("subscription_id")
  weekday        Int
  isOffDay       Boolean          @default(false) @map("is_off_day")
  createdAt      DateTime         @default(now()) @map("created_at")
  subscription   UserSubscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@map("subscription_schedules")
}

model SubscriptionAddOn {
  id             String           @id @default(uuid())
  subscriptionId String           @map("subscription_id")
  addOnId        String           @map("add_on_id")
  createdAt      DateTime         @default(now()) @map("created_at")
  subscription   UserSubscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  addOn          AddOn            @relation(fields: [addOnId], references: [id], onDelete: Cascade)

  @@map("subscription_add_ons")
}

model Vehicle {
  id          String   @id @default(uuid())
  model       String
  plateNumber String   @unique @map("plate_number")
  color       String?
  capacity    Int?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  drivers     Driver[]
  trips       Trip[]

  @@map("vehicles")
}

model Driver {
  id               String           @id @default(uuid())
  profileId        String?          @map("profile_id")
  vehicleId        String?          @map("vehicle_id")
  availability     Boolean          @default(true)
  rating           Decimal?         @default(5.0) @db.Decimal(2, 1)
  isSuspended      Boolean          @default(false) @map("is_suspended")
  suspensionReason String?          @map("suspension_reason") @db.Text
  createdAt        DateTime         @default(now()) @map("created_at")
  updatedAt        DateTime         @updatedAt @map("updated_at")
  profile          Profile?         @relation(fields: [profileId], references: [id], onDelete: Cascade)
  vehicle          Vehicle?         @relation(fields: [vehicleId], references: [id], onDelete: SetNull)
  trips            Trip[]
  locations        DriverLocation[]

  @@map("drivers")
}

model Trip {
  id                   String              @id @default(uuid())
  subscriptionId       String?             @map("subscription_id")
  riderId              String?             @map("rider_id")
  driverId             String?             @map("driver_id")
  vehicleId            String?             @map("vehicle_id")
  scheduledDate        DateTime            @map("scheduled_date") @db.Date
  scheduledPickupTime  DateTime?           @map("scheduled_pickup_time")
  scheduledDropoffTime DateTime?           @map("scheduled_dropoff_time")
  actualPickupTime     DateTime?           @map("actual_pickup_time")
  actualDropoffTime    DateTime?           @map("actual_dropoff_time")
  pickupLocation       String              @map("pickup_location") @db.Text
  dropoffLocation      String              @map("dropoff_location") @db.Text
  status               TripStatus          @default(SCHEDULED)
  cancelledBy          String?             @map("cancelled_by")
  createdAt            DateTime            @default(now()) @map("created_at")
  updatedAt            DateTime            @updatedAt @map("updated_at")
  subscription         UserSubscription?   @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
  rider                Rider?              @relation(fields: [riderId], references: [id], onDelete: SetNull)
  driver               Driver?             @relation(fields: [driverId], references: [id], onDelete: SetNull)
  vehicle              Vehicle?            @relation(fields: [vehicleId], references: [id], onDelete: SetNull)
  canceller            Profile?            @relation("CancelledBy", fields: [cancelledBy], references: [id], onDelete: SetNull)
  locations            DriverLocation[]
  walletTransactions   WalletTransaction[]
  safetyReports        SafetyReport[]

  @@map("trips")
}

model DriverLocation {
  id         BigInt   @id @default(autoincrement())
  driverId   String   @map("driver_id")
  tripId     String?  @map("trip_id")
  lat        Float
  lng        Float
  recordedAt DateTime @default(now()) @map("recorded_at")
  driver     Driver   @relation(fields: [driverId], references: [id], onDelete: Cascade)
  trip       Trip?    @relation(fields: [tripId], references: [id], onDelete: SetNull)

  @@map("driver_locations")
}

model Wallet {
  id           String              @id @default(uuid())
  userId       String              @unique @map("user_id")
  balanceSar   Decimal             @default(0.00) @map("balance_sar") @db.Decimal(10, 2)
  createdAt    DateTime            @default(now()) @map("created_at")
  updatedAt    DateTime            @updatedAt @map("updated_at")
  user         Profile             @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions WalletTransaction[]

  @@map("wallets")
}

model WalletTransaction {
  id        String   @id @default(uuid())
  walletId  String   @map("wallet_id")
  tripId    String?  @map("trip_id")
  amountSar Decimal  @map("amount_sar") @db.Decimal(10, 2)
  txType    String   @map("tx_type")
  createdAt DateTime @default(now()) @map("created_at")
  wallet    Wallet   @relation(fields: [walletId], references: [id], onDelete: Cascade)
  trip      Trip?    @relation(fields: [tripId], references: [id], onDelete: SetNull)

  @@map("wallet_transactions")
}

model Payment {
  id             String            @id @default(uuid())
  userId         String            @map("user_id")
  subscriptionId String?           @map("subscription_id")
  amountSar      Decimal           @map("amount_sar") @db.Decimal(10, 2)
  status         PaymentStatus     @default(PENDING)
  gateway        String?           @default("myfatoorah")
  externalRef    String?           @map("external_ref")
  createdAt      DateTime          @default(now()) @map("created_at")
  user           Profile           @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscription   UserSubscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)

  @@map("payments")
}

model LoyaltyAccount {
  id            String               @id @default(uuid())
  userId        String               @unique @map("user_id")
  pointsBalance Int                  @default(0) @map("points_balance")
  createdAt     DateTime             @default(now()) @map("created_at")
  updatedAt     DateTime             @updatedAt @map("updated_at")
  user          Profile              @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions  LoyaltyTransaction[]

  @@map("loyalty_accounts")
}

model LoyaltyTransaction {
  id        String         @id @default(uuid())
  accountId String         @map("account_id")
  points    Int
  reason    String?
  createdAt DateTime       @default(now()) @map("created_at")
  account   LoyaltyAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@map("loyalty_transactions")
}

model SafetyReport {
  id          String                   @id @default(uuid())
  userId      String?                  @map("user_id")
  tripId      String?                  @map("trip_id")
  category    String
  description String                   @db.Text
  status      SafetyStatus             @default(PENDING)
  reviewedBy  String?                  @map("reviewed_by")
  createdAt   DateTime                 @default(now()) @map("created_at")
  updatedAt   DateTime                 @updatedAt @map("updated_at")
  user        Profile?                 @relation("UserSafetyReports", fields: [userId], references: [id], onDelete: SetNull)
  trip        Trip?                    @relation(fields: [tripId], references: [id], onDelete: SetNull)
  reviewer    Profile?                 @relation("ReviewedBy", fields: [reviewedBy], references: [id], onDelete: SetNull)
  attachments SafetyReportAttachment[]

  @@map("safety_reports")
}

model SafetyReportAttachment {
  id        String        @id @default(uuid())
  reportId  String?       @map("report_id")
  filePath  String        @map("file_path") @db.Text
  createdAt DateTime      @default(now()) @map("created_at")
  report    SafetyReport? @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@map("safety_report_attachments")
}

model Notification {
  id        String   @id @default(uuid())
  userId    String?  @map("user_id")
  title     String
  message   String   @db.Text
  type      String
  isRead    Boolean  @default(false) @map("is_read")
  createdAt DateTime @default(now()) @map("created_at")
  user      Profile? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

model SystemConfiguration {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("system_configurations")
}

model TripGenerationLog {
  id             String   @id @default(uuid())
  runDate        DateTime @map("run_date") @db.Date
  generatedCount Int      @default(0) @map("generated_count")
  failedCount    Int      @default(0) @map("failed_count")
  notes          String?  @db.Text
  createdAt      DateTime @default(now()) @map("created_at")

  @@map("trip_generation_logs")
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?  @map("user_id")
  action    String
  details   String?  @db.Text
  ipAddress String?  @map("ip_address")
  createdAt DateTime @default(now()) @map("created_at")
  user      Profile? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("audit_logs")
}

model DriverApplication {
  id                     String                  @id @default(uuid())
  userId                 String                  @map("user_id")
  vehicleType            VehicleType             @map("vehicle_type")
  vehicleCategory        String                  @map("vehicle_category")
  vehicleBrand           String                  @map("vehicle_brand")
  vehicleModel           String                  @map("vehicle_model")
  vehicleYear            Int                     @map("vehicle_year")
  plateNumber            String                  @map("plate_number")
  vehicleColor           String                  @map("vehicle_color")
  vehicleCapacity        Int                     @map("vehicle_capacity")
  licenseNumber          String                  @map("license_number")
  driverLicenseUrl       String?                 @map("driver_license_url") @db.Text
  vehicleRegistrationUrl String?                 @map("vehicle_registration_url") @db.Text
  nationalIdUrl          String?                 @map("national_id_url") @db.Text
  driverNotes            String?                 @map("driver_notes") @db.Text
  city                   String
  serviceArea            String                  @map("service_area")
  femaleDriver           Boolean                 @default(false) @map("female_driver")
  status                 DriverApplicationStatus @default(PENDING)
  adminResponse          String?                 @map("admin_response") @db.Text
  reviewedBy             String?                 @map("reviewed_by")
  reviewedAt             DateTime?               @map("reviewed_at")
  submittedAt            DateTime                @default(now()) @map("submitted_at")
  resubmittedAt          DateTime?               @map("resubmitted_at")
  createdAt              DateTime                @default(now()) @map("created_at")
  updatedAt              DateTime                @updatedAt @map("updated_at")
  applicant              Profile                 @relation("ApplicationApplicant", fields: [userId], references: [id], onDelete: Cascade)
  reviewer               Profile?                @relation("ApplicationReviewer", fields: [reviewedBy], references: [id], onDelete: SetNull)

  @@map("driver_applications")
}
